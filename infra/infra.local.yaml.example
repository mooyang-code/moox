# infra.local.yaml 模板：复制为 infra.local.yaml（gitignored）后填入真实部署值。
# 该文件覆盖 infra/infra.yaml 的占位默认。切勿把真实 IP 提交入库。
# 用法：cp infra/infra.local.yaml.example infra/infra.local.yaml，替换 <...> 占位。
services:
  storage_access:
    host: <storage-host>
    port: 20201
  xdata:
    host: <storage-host>
    port: 20201
  admin_gateway:
    host: <admin-host>
    port: 11000
  web_host:
    host: <web-host>
    port: 10080
  trade:
    host: 127.0.0.1
    port: 11200
remote:
  host: <deploy-host>
  ssh: ubuntu@<deploy-host>
