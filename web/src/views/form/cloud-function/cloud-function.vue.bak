<template>
  <div class="moox-page">
    <a-spin :loading="loading">
      <div class="moox-inner">
        <a-space wrap>
          <a-select v-model="form.cloudAccountId" placeholder="请选择云账户" style="width: 200px" allow-clear>
            <a-option v-for="account in cloudAccountOptions" :key="account.account_id" :value="account.account_id">
              {{ account.account_name }} ({{ getProviderName(account.provider) }})
            </a-option>
          </a-select>
          <a-input v-model="form.namespace" placeholder="请输入命名空间" allow-clear />
          <a-select placeholder="地区" v-model="form.region" style="width: 180px" allow-clear>
            <a-option value="ap-bangkok">亚太东南（曼谷）</a-option>
            <a-option value="ap-beijing">华北地区（北京）</a-option>
            <a-option value="ap-chengdu">西南地区（成都）</a-option>
            <a-option value="ap-chongqing">西南地区（重庆）</a-option>
            <a-option value="ap-guangzhou">华南地区（广州）</a-option>
            <a-option value="ap-hongkong">港澳台地区（中国香港）</a-option>
            <a-option value="ap-jakarta">亚太东南（雅加达）</a-option>
            <a-option value="ap-nanjing">华东地区（南京）</a-option>
            <a-option value="ap-seoul">亚太东北（首尔）</a-option>
            <a-option value="ap-shanghai">华东地区（上海）</a-option>
            <a-option value="ap-shanghai-fsi">华东地区（上海金融）</a-option>
            <a-option value="ap-shenzhen-fsi">华南地区（深圳金融）</a-option>
            <a-option value="ap-singapore">亚太东南（新加坡）</a-option>
            <a-option value="ap-tokyo">亚太东北（东京）</a-option>
            <a-option value="eu-frankfurt">欧洲地区（法兰克福）</a-option>
            <a-option value="na-ashburn">美国东部（弗吉尼亚）</a-option>
            <a-option value="na-siliconvalley">美国西部（硅谷）</a-option>
            <a-option value="sa-saopaulo">南美地区（圣保罗）</a-option>
          </a-select>
          <a-select placeholder="节点类型" v-model="form.nodeType" style="width: 120px" allow-clear>
            <a-option value="scf">云函数</a-option>
            <a-option value="server">服务器</a-option>
          </a-select>
          <a-select placeholder="节点状态" v-model="form.status" style="width: 120px" allow-clear>
            <a-option value="1">在线</a-option>
            <a-option value="0">离线</a-option>
            <a-option value="2">维护中</a-option>
            <a-option value="3">过载</a-option>
          </a-select>
          <a-button type="primary" @click="search">
            <template #icon><icon-search /></template>
            <span>查询</span>
          </a-button>
          <a-button @click="reset">
            <template #icon><icon-refresh /></template>
            <span>重置</span>
          </a-button>
        </a-space>

        <a-row>
          <a-space wrap>
            <a-button type="primary" @click="onAdd">
              <template #icon><icon-plus /></template>
              <span>新增</span>
            </a-button>
            <a-button type="primary" status="success" @click="onBatchAdd">
              <template #icon><icon-plus-circle /></template>
              <span>批量新增</span>
            </a-button>
            <a-button type="primary" status="warning" @click="batchDeploy">
              <template #icon><icon-upload /></template>
              <span>批量部署</span>
            </a-button>
            <a-button type="primary" status="danger" @click="batchDelete">
              <template #icon><icon-delete /></template>
              <span>批量删除</span>
            </a-button>
            <a-button type="outline" @click="onCloudAccountManage">
              <template #icon><icon-settings /></template>
              <span>云账户管理</span>
            </a-button>
          </a-space>
        </a-row>

        <!-- 选择状态提示 -->
        <a-alert
          v-if="selectedKeys.length > 0"
          type="info"
          style="margin: 16px 0;"
          :closable="true"
          @close="selectedKeys = []"
        >
          <template #title>
            已选择 {{ selectedKeys.length }} 个节点
          </template>
          <div style="font-size: 12px; color: #86909c;">
            提示：批量操作只会对当前选中的节点生效。切换页面时会保留其他页的选择状态。
          </div>
        </a-alert>

        <a-table
          row-key="node_id"
          :data="functionList"
          :bordered="{ cell: true }"
          :loading="loading"
          :scroll="{ x: 1320, y: '100%' }"
          :pagination="paginationConfig"
          :row-selection="{ type: 'checkbox', showCheckedAll: true }"
          :selected-keys="selectedKeys"
          @select="select"
          @select-all="selectAll"
          @page-change="onPageChange"
          @page-size-change="onPageSizeChange"
        >
          <template #columns>
            <a-table-column title="节点ID" data-index="node_id" :width="120">
              <template #cell="{ record }">
                <a-link @click="onViewNodeDetail(record)">{{ record.node_id }}</a-link>
              </template>
            </a-table-column>
            <a-table-column title="云账户ID" data-index="cloud_account_id" :width="120"></a-table-column>
            <a-table-column title="命名空间" data-index="namespace" :width="120"></a-table-column>
            <a-table-column title="节点类型" data-index="node_type" :width="100">
              <template #cell="{ record }">
                <a-tag bordered size="small" :color="record.node_type === 'scf' ? 'blue' : 'orange'">
                  {{ record.node_type === 'scf' ? '云函数' : '服务器' }}
                </a-tag>
              </template>
            </a-table-column>
            <a-table-column title="地区" data-index="region" :width="150">
              <template #cell="{ record }">
                {{ getRegionName(record.region) }}
              </template>
            </a-table-column>
            <a-table-column title="IP地址" data-index="ip_address" :width="120"></a-table-column>
            <a-table-column title="支持的采集器" data-index="supported_collectors" :width="160">
              <template #cell="{ record }">
                <div v-if="record.supported_collectors">
                  <a-tag v-for="item in parseJSON(record.supported_collectors)" :key="item" 
                    bordered size="small" style="margin: 2px">{{ item }}</a-tag>
                </div>
              </template>
            </a-table-column>
            <a-table-column title="状态" :width="100" align="center">
              <template #cell="{ record }">
                <a-tag bordered size="small" 
                  :color="getStatusColor(record.status)">
                  {{ getStatusText(record.status) }}
                </a-tag>
              </template>
            </a-table-column>
            <a-table-column title="操作" :width="240" align="center" fixed="right">
              <template #cell="{ record }">
                <a-space>
                  <a-button v-if="record.node_type === 'scf'" type="primary" size="mini" @click="onDeploy(record)">
                    <template #icon><icon-upload /></template>
                    <span>部署</span>
                  </a-button>
                  <a-button type="primary" size="mini" @click="onUpdate(record)">
                    <template #icon><icon-edit /></template>
                    <span>修改</span>
                  </a-button>
                  <a-popconfirm type="warning" content="确定删除该节点吗?">
                    <a-button type="primary" status="danger" size="mini" @click="handleDelete(record)">
                      <template #icon><icon-delete /></template>
                      <span>删除</span>
                    </a-button>
                  </a-popconfirm>
                </a-space>
              </template>
            </a-table-column>
          </template>
        </a-table>
      </div>
    </a-spin>

    <a-modal v-model:visible="open" @close="afterClose" @ok="handleOk" @cancel="afterClose" width="800px">
      <template #title> {{ title }} </template>
      <div>
        <a-form ref="formRef" auto-label-width :rules="rules" :model="addForm" :layout="'vertical'">
          <a-row :gutter="16">
            <a-col :span="12">
              <a-form-item field="cloud_account_id" label="云账户" validate-trigger="blur">
                <a-select v-model="addForm.cloud_account_id" placeholder="请选择云账户">
                  <a-option v-for="account in cloudAccountOptions" :key="account.account_id" :value="account.account_id">
                    {{ account.account_name }} ({{ getProviderName(account.provider) }})
                  </a-option>
                </a-select>
              </a-form-item>
            </a-col>
            <a-col :span="12">
              <a-form-item field="node_type" label="节点类型" validate-trigger="blur">
                <a-select v-model="addForm.node_type" placeholder="请选择节点类型">
                  <a-option value="scf">云函数</a-option>
                  <a-option value="server">服务器</a-option>
                </a-select>
              </a-form-item>
            </a-col>
          </a-row>
          <a-row :gutter="16">
            <a-col :span="12">
              <a-form-item field="region" label="部署地区" validate-trigger="blur">
                <a-select v-model="addForm.region" placeholder="请选择部署地区" allow-clear>
                  <a-option value="ap-bangkok">亚太东南（曼谷）</a-option>
                  <a-option value="ap-beijing">华北地区（北京）</a-option>
                  <a-option value="ap-chengdu">西南地区（成都）</a-option>
                  <a-option value="ap-chongqing">西南地区（重庆）</a-option>
                  <a-option value="ap-guangzhou">华南地区（广州）</a-option>
                  <a-option value="ap-hongkong">港澳台地区（中国香港）</a-option>
                  <a-option value="ap-jakarta">亚太东南（雅加达）</a-option>
                  <a-option value="ap-nanjing">华东地区（南京）</a-option>
                  <a-option value="ap-seoul">亚太东北（首尔）</a-option>
                  <a-option value="ap-shanghai">华东地区（上海）</a-option>
                  <a-option value="ap-shanghai-fsi">华东地区（上海金融）</a-option>
                  <a-option value="ap-shenzhen-fsi">华南地区（深圳金融）</a-option>
                  <a-option value="ap-singapore">亚太东南（新加坡）</a-option>
                  <a-option value="ap-tokyo">亚太东北（东京）</a-option>
                  <a-option value="eu-frankfurt">欧洲地区（法兰克福）</a-option>
                  <a-option value="na-ashburn">美国东部（弗吉尼亚）</a-option>
                  <a-option value="na-siliconvalley">美国西部（硅谷）</a-option>
                  <a-option value="sa-saopaulo">南美地区（圣保罗）</a-option>
                </a-select>
              </a-form-item>
            </a-col>
          </a-row>
          <a-row :gutter="16">
            <a-col :span="12">
              <a-form-item field="ip_address" label="IP地址">
                <a-input v-model="addForm.ip_address" placeholder="请输入IP地址（可选）" allow-clear />
              </a-form-item>
            </a-col>
          </a-row>
          <a-row :gutter="16">
            <a-col :span="12">
              <a-form-item field="status" label="状态">
                <a-select v-model="addForm.status" placeholder="请选择状态">
                  <a-option value="0">离线</a-option>
                  <a-option value="1">在线</a-option>
                  <a-option value="2">维护中</a-option>
                  <a-option value="3">过载</a-option>
                </a-select>
              </a-form-item>
            </a-col>
          </a-row>
          <a-form-item field="supported_collectors" label="支持的采集器类型">
            <a-select v-model="supportedCollectorsList" placeholder="请选择支持的采集器" multiple>
              <a-option value="kline">K线数据</a-option>
              <a-option value="ticker">Ticker数据</a-option>
              <a-option value="orderbook">订单簿数据</a-option>
              <a-option value="trade">交易数据</a-option>
              <a-option value="news">新闻数据</a-option>
            </a-select>
          </a-form-item>
          <a-form-item field="capacity" label="节点能力配置（JSON格式）">
            <a-textarea v-model="addForm.capacity" placeholder='{"cpu": 2, "memory": 512, "max_tasks": 10}' 
              :rows="3" />
          </a-form-item>
          <a-form-item field="metadata" label="元数据（JSON格式）">
            <a-textarea v-model="addForm.metadata" placeholder="请输入元数据（JSON格式）" :rows="3" />
          </a-form-item>
        </a-form>
      </div>
    </a-modal>

    <!-- 节点详情弹窗 -->
    <a-modal v-model:visible="nodeDetailVisible" :footer="false" width="800px">
      <template #title>节点详情信息</template>
      <a-descriptions :column="2" bordered>
        <a-descriptions-item label="节点ID">{{ nodeDetail.node_id }}</a-descriptions-item>
        <a-descriptions-item label="云账户ID">{{ nodeDetail.cloud_account_id }}</a-descriptions-item>
        <a-descriptions-item label="命名空间">{{ nodeDetail.namespace }}</a-descriptions-item>
        <a-descriptions-item label="节点类型">
          <a-tag bordered size="small" :color="nodeDetail.node_type === 'scf' ? 'blue' : 'orange'">
            {{ nodeDetail.node_type === 'scf' ? '云函数' : '服务器' }}
          </a-tag>
        </a-descriptions-item>
        <a-descriptions-item label="地区">{{ getRegionName(nodeDetail.region || '') }}</a-descriptions-item>
        <a-descriptions-item label="IP地址">{{ nodeDetail.ip_address }}</a-descriptions-item>
        <a-descriptions-item label="状态">
          <a-tag bordered size="small" :color="getStatusColor(nodeDetail.status)">
            {{ getStatusText(nodeDetail.status) }}
          </a-tag>
        </a-descriptions-item>
        <a-descriptions-item label="创建时间">{{ nodeDetail.create_time }}</a-descriptions-item>
        <a-descriptions-item label="更新时间">{{ nodeDetail.update_time }}</a-descriptions-item>
      </a-descriptions>
      
      <a-divider />
      
      <a-descriptions :column="1" bordered>
        <a-descriptions-item label="支持的采集器">
          <a-space wrap>
            <a-tag v-for="item in parseJSON(nodeDetail.supported_collectors)" :key="item" 
              bordered size="small">{{ item }}</a-tag>
          </a-space>
        </a-descriptions-item>
        <a-descriptions-item label="当前负载">
          <pre>{{ formatJSON(nodeDetail.current_load) }}</pre>
        </a-descriptions-item>
        <a-descriptions-item label="节点能力">
          <pre>{{ formatJSON(nodeDetail.capacity) }}</pre>
        </a-descriptions-item>
        <a-descriptions-item label="元数据">
          <pre>{{ formatJSON(nodeDetail.metadata) }}</pre>
        </a-descriptions-item>
      </a-descriptions>
    </a-modal>

    <!-- 云账户管理弹窗 -->
    <a-modal v-model:visible="cloudAccountVisible" width="900px" :footer="false">
      <template #title>云账户管理</template>
      <div>
        <a-space wrap style="margin-bottom: 16px">
          <a-button type="primary" size="small" @click="onAddCloudAccount">
            <template #icon><icon-plus /></template>
            <span>新增云账户</span>
          </a-button>
        </a-space>
        
        <a-table 
          :data="cloudAccountList"
          :loading="cloudAccountLoading"
          :pagination="false"
          row-key="account_id"
        >
          <template #columns>
            <a-table-column title="账户ID" data-index="account_id" :width="100"></a-table-column>
            <a-table-column title="账户名称" data-index="account_name" :width="120"></a-table-column>
            <a-table-column title="云厂商" data-index="provider" :width="80">
              <template #cell="{ record }">
                <a-tag bordered size="small">
                  {{ getProviderName(record.provider) }}
                </a-tag>
              </template>
            </a-table-column>
            <a-table-column title="密钥ID" data-index="secret_id" :width="100"></a-table-column>
            <a-table-column title="密钥" data-index="secret_key" :width="150">
              <template #cell="{ record }">
                <span style="font-family: monospace">{{ record.secret_key }}</span>
              </template>
            </a-table-column>
            <a-table-column title="创建时间" data-index="create_time" :width="160"></a-table-column>
            <a-table-column title="操作" :width="100" align="center" fixed="right">
              <template #cell="{ record }">
                <a-space>
                  <a-button type="primary" size="mini" @click="onEditCloudAccount(record)">
                    <template #icon><icon-edit /></template>
                  </a-button>
                  <a-popconfirm 
                    type="warning" 
                    content="确定删除该云账户吗？删除后相关云函数将无法使用。"
                    @ok="handleDeleteCloudAccount(record)"
                  >
                    <a-button type="primary" status="danger" size="mini">
                      <template #icon><icon-delete /></template>
                    </a-button>
                  </a-popconfirm>
                </a-space>
              </template>
            </a-table-column>
          </template>
        </a-table>
      </div>
    </a-modal>

    <!-- 云账户编辑弹窗 -->
    <a-modal 
      v-model:visible="cloudAccountEditVisible" 
      :title="cloudAccountEditTitle"
      width="600px"
      @ok="handleCloudAccountSubmit"
      @cancel="cloudAccountEditVisible = false"
    >
      <a-form ref="cloudAccountFormRef" :model="cloudAccountForm" :rules="cloudAccountRules" layout="vertical">
        <a-form-item field="account_id" label="云账户ID" validate-trigger="blur">
          <a-input 
            v-model="cloudAccountForm.account_id" 
            placeholder="请输入云厂商分配的账户ID" 
            :disabled="cloudAccountEditTitle === '编辑云账户'"
          />
          <template #extra>
            <div style="color: #86909c; font-size: 12px; margin-top: 4px">
              {{ getAccountIdHelpText() }}
            </div>
          </template>
        </a-form-item>
        <a-form-item field="account_name" label="账户名称" validate-trigger="blur">
          <a-input v-model="cloudAccountForm.account_name" placeholder="请输入账户名称" />
        </a-form-item>
        <a-form-item field="provider" label="云厂商">
          <a-select v-model="cloudAccountForm.provider" placeholder="请选择云厂商">
            <a-option value="tencent">腾讯云</a-option>
            <a-option value="aliyun">阿里云</a-option>
            <a-option value="aws">AWS</a-option>
          </a-select>
        </a-form-item>
        <a-form-item field="secret_id" label="密钥ID (SecretId/AccessKeyId)" validate-trigger="blur">
          <a-input v-model="cloudAccountForm.secret_id" placeholder="请输入密钥ID" />
        </a-form-item>
        <a-form-item field="secret_key" label="密钥 (SecretKey/AccessKeySecret)" validate-trigger="blur">
          <a-input-password 
            v-model="cloudAccountForm.secret_key" 
            placeholder="请输入密钥"
            :invisible-button="false"
          />
          <template #extra>
            <div style="color: #86909c; font-size: 12px; margin-top: 4px">
              提示：密钥将加密存储，更新时如不修改请留空
            </div>
          </template>
        </a-form-item>
        <a-form-item field="extra_config" label="额外配置 (JSON格式，可选)">
          <a-textarea 
            v-model="cloudAccountForm.extra_config" 
            placeholder='{"region": "ap-guangzhou"}'
            :rows="3"
          />
        </a-form-item>
      </a-form>
    </a-modal>

    <!-- 云函数部署弹窗 -->
    <a-modal 
      v-model:visible="deployVisible" 
      title="部署云函数"
      width="600px"
      @ok="handleDeploySubmit"
      @cancel="deployVisible = false"
    >
      <a-form ref="deployFormRef" :model="deployForm" :rules="deployRules" layout="vertical">
        <a-form-item label="节点信息">
          <a-descriptions :column="2" bordered size="small">
            <a-descriptions-item label="节点ID">{{ deployForm.node_id }}</a-descriptions-item>
            <a-descriptions-item label="命名空间">{{ deployForm.namespace }}</a-descriptions-item>
            <a-descriptions-item label="地区">{{ getRegionName(deployForm.region) }}</a-descriptions-item>
            <a-descriptions-item label="云账户">{{ deployForm.cloud_account_id }}</a-descriptions-item>
          </a-descriptions>
        </a-form-item>
        
        <a-form-item field="zip_file" label="函数代码包" validate-trigger="change">
          <a-upload
            :auto-upload="false"
            :limit="1"
            accept=".zip"
            @change="handleFileChange"
            :file-list="fileList"
          >
            <template #upload-button>
              <a-button type="primary">
                <template #icon><icon-upload /></template>
                选择ZIP文件
              </a-button>
            </template>
          </a-upload>
          <template #extra>
            <div style="color: #86909c; font-size: 12px; margin-top: 4px">
              请上传云函数代码的ZIP压缩包，文件大小不超过100MB
            </div>
          </template>
        </a-form-item>
        
        <a-form-item label="部署说明">
          <a-textarea 
            v-model="deployForm.description" 
            placeholder="请输入本次部署的说明（可选）"
            :rows="3"
          />
        </a-form-item>
      </a-form>
    </a-modal>

    <!-- 批量部署弹窗 -->
    <a-modal
      v-model:visible="batchDeployVisible"
      title="批量部署云函数"
      width="700px"
      :ok-text="batchDeployProgress.show && !batchDeployProgress.isProcessing ? '关闭' : '开始部署'"
      :cancel-button-props="{ style: { display: batchDeployProgress.show ? 'none' : 'inline-block' } }"
      :ok-loading="batchDeployProgress.isProcessing"
      :closable="!batchDeployProgress.isProcessing"
      :mask-closable="!batchDeployProgress.isProcessing"
      :escape-to-close="!batchDeployProgress.isProcessing"
      @before-ok="handleBatchDeployBeforeOk"
      @cancel="batchDeployVisible = false"
    >
      <a-form ref="batchDeployFormRef" :model="batchDeployForm" :rules="batchDeployRules" layout="vertical">
        <a-form-item label="选中的节点">
          <a-table
            :data="selectedNodesForDeploy"
            :pagination="false"
            :scroll="{ y: 200 }"
            size="small"
          >
            <template #columns>
              <a-table-column title="节点ID" data-index="node_id" :width="180"></a-table-column>
              <a-table-column title="命名空间" data-index="namespace" :width="120"></a-table-column>
              <a-table-column title="地区" data-index="region" :width="150">
                <template #cell="{ record }">
                  {{ getRegionName(record.region) }}
                </template>
              </a-table-column>
              <a-table-column title="状态" :width="80" align="center">
                <template #cell="{ record }">
                  <a-tag bordered size="small" :color="getStatusColor(record.status)">
                    {{ getStatusText(record.status) }}
                  </a-tag>
                </template>
              </a-table-column>
            </template>
          </a-table>
        </a-form-item>

        <a-form-item field="zip_file" label="函数代码包" validate-trigger="change">
          <a-upload
            :file-list="batchFileList"
            :auto-upload="false"
            :limit="1"
            accept=".zip"
            @change="handleBatchFileChange"
            :show-file-list="true"
          >
            <template #upload-button>
              <a-button type="primary" v-if="batchFileList.length === 0">
                <template #icon><icon-upload /></template>
                选择ZIP文件
              </a-button>
            </template>
          </a-upload>
          <template #extra>
            <div style="color: #86909c; font-size: 12px; margin-top: 4px">
              请上传云函数代码的ZIP压缩包，文件大小不超过100MB。该文件将部署到所有选中的节点。
            </div>
            <div v-if="batchDeployForm.zip_file" style="color: #165dff; font-size: 12px; margin-top: 4px">
              ✓ 已选择文件：{{ batchDeployForm.zip_file.name }} ({{ (batchDeployForm.zip_file.size / 1024).toFixed(2) }}KB)
            </div>
          </template>
        </a-form-item>
        




        <div v-if="batchDeployProgress.show" style="margin-top: 16px; padding: 16px; background-color: #f5f7fa; border-radius: 4px;">
          <div style="margin-bottom: 12px; font-weight: 500; font-size: 16px; color: #1d2129;">
            部署进度：{{ batchDeployProgress.current }} / {{ batchDeployProgress.total }}
          </div>
          <!-- 自定义进度条 -->
          <div style="margin-bottom: 8px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
              <span style="font-size: 14px; color: #1d2129;">进度</span>
              <span style="font-size: 14px; color: #1d2129; font-weight: 500;">{{ deployProgressPercent }}%</span>
            </div>
            <div style="width: 100%; height: 12px; background-color: #f2f3f5; border-radius: 6px; overflow: hidden;">
              <div
                style="height: 100%; background-color: #165dff; border-radius: 6px; transition: width 0.3s ease;"
                :style="{ width: deployProgressPercent + '%' }"
              ></div>
            </div>
          </div>
          <div v-if="batchDeployProgress.isProcessing" style="margin-top: 12px; color: #4e5969; font-size: 14px;">
            <icon-loading spin style="margin-right: 4px;" />
            正在部署到第 {{ batchDeployProgress.current + 1 }} 个节点...
          </div>
        </div>
        
        <!-- 批量部署结果显示 -->
        <div v-if="batchDeployProgress.show && !batchDeployProgress.isProcessing" style="margin-top: 16px;">
          <div style="display: flex; align-items: center; margin-bottom: 16px; font-size: 18px; font-weight: 600;">
            <IconCheckCircle v-if="batchDeployProgress.errors.length === 0" style="color: #00b42a; margin-right: 8px; font-size: 20px;" />
            <IconExclamationCircle v-else style="color: #ff7d00; margin-right: 8px; font-size: 20px;" />
            <span>批量部署结果</span>
            <span style="margin-left: 12px; color: #00b42a; font-size: 16px;">成功: {{ batchDeployProgress.success.length }}</span>
            <span v-if="batchDeployProgress.errors.length > 0" style="margin-left: 12px; color: #f53f3f; font-size: 16px;">失败: {{ batchDeployProgress.errors.length }}</span>
          </div>

          <!-- 成功部署的节点 -->
          <div v-if="batchDeployProgress.success.length > 0" style="margin-bottom: 16px;">
            <div style="display: flex; align-items: center; margin-bottom: 12px;">
              <IconCheck style="color: #00b42a; margin-right: 6px;" />
              <span style="font-weight: 500; color: #00b42a;">部署成功的节点 ({{ batchDeployProgress.success.length }})</span>
            </div>
            <div style="background-color: #f6ffed; border: 1px solid #b7eb8f; border-radius: 6px; padding: 16px; max-height: 200px; overflow-y: auto;">
              <div v-for="node in batchDeployProgress.success" :key="node.node_id"
                style="margin-bottom: 8px; padding: 8px 12px; background-color: #fff; border-radius: 4px; border-left: 3px solid #52c41a;">
                <div style="font-weight: 500; color: #262626;">{{ node.node_id }}</div>
                <div v-if="node.namespace" style="font-size: 12px; color: #8c8c8c; margin-top: 2px;">命名空间: {{ node.namespace }}</div>
              </div>
            </div>
          </div>

          <!-- 失败的节点 -->
          <div v-if="batchDeployProgress.errors.length > 0">
            <div style="display: flex; align-items: center; margin-bottom: 12px;">
              <IconClose style="color: #f53f3f; margin-right: 6px;" />
              <span style="font-weight: 500; color: #f53f3f;">部署失败的节点 ({{ batchDeployProgress.errors.length }})</span>
            </div>
            <div style="background-color: #fff2f0; border: 1px solid #ffccc7; border-radius: 6px; padding: 16px; max-height: 200px; overflow-y: auto;">
              <div v-for="error in batchDeployProgress.errors" :key="error.node_id"
                style="margin-bottom: 8px; padding: 8px 12px; background-color: #fff; border-radius: 4px; border-left: 3px solid #ff4d4f;">
                <div style="font-weight: 500; color: #262626;">{{ error.node_id }}</div>
                <div style="font-size: 12px; color: #f53f3f; margin-top: 2px;">{{ error.message }}</div>
              </div>
            </div>
          </div>

          <div style="margin-top: 16px; padding: 12px; background-color: #f5f7fa; border-radius: 4px; text-align: center; color: #4e5969; font-size: 14px;">
            本次共处理 {{ batchDeployProgress.total }} 个节点，成功 {{ batchDeployProgress.success.length }} 个，失败 {{ batchDeployProgress.errors.length }} 个
          </div>
        </div>
      </a-form>
    </a-modal>

    <!-- 批量新增弹窗 -->
    <a-modal
      v-model:visible="batchAddVisible"
      title="批量新增云函数"
      width="700px"
      :ok-text="batchAddProgress.show && !batchAddProgress.isProcessing ? '关闭' : '开始创建'"
      :cancel-button-props="{ style: { display: batchAddProgress.show ? 'none' : 'inline-block' } }"
      :ok-loading="batchAddProgress.isProcessing"
      :closable="!batchAddProgress.isProcessing"
      :mask-closable="!batchAddProgress.isProcessing"
      :escape-to-close="!batchAddProgress.isProcessing"
      @before-ok="handleBatchAddBeforeOk"
      @cancel="batchAddVisible = false"
    >
      <a-form ref="batchAddFormRef" :model="batchAddForm" :rules="batchAddRules" layout="vertical">
        <a-row :gutter="16">
          <a-col :span="12">
            <a-form-item field="cloud_account_id" label="云账户" validate-trigger="blur" required>
              <a-select v-model="batchAddForm.cloud_account_id" placeholder="请选择云账户">
                <a-option v-for="account in cloudAccountOptions" :key="account.account_id" :value="account.account_id">
                  {{ account.account_name }} ({{ getProviderName(account.provider) }})
                </a-option>
              </a-select>
            </a-form-item>
          </a-col>
          <a-col :span="12">
            <a-form-item field="region" label="部署地区" validate-trigger="blur" required>
              <a-select v-model="batchAddForm.region" placeholder="请选择部署地区">
                <a-option value="ap-bangkok">亚太东南（曼谷）</a-option>
                <a-option value="ap-beijing">华北地区（北京）</a-option>
                <a-option value="ap-chengdu">西南地区（成都）</a-option>
                <a-option value="ap-chongqing">西南地区（重庆）</a-option>
                <a-option value="ap-guangzhou">华南地区（广州）</a-option>
                <a-option value="ap-hongkong">港澳台地区（中国香港）</a-option>
                <a-option value="ap-jakarta">亚太东南（雅加达）</a-option>
                <a-option value="ap-nanjing">华东地区（南京）</a-option>
                <a-option value="ap-seoul">亚太东北（首尔）</a-option>
                <a-option value="ap-shanghai">华东地区（上海）</a-option>
                <a-option value="ap-shanghai-fsi">华东地区（上海金融）</a-option>
                <a-option value="ap-shenzhen-fsi">华南地区（深圳金融）</a-option>
                <a-option value="ap-singapore">亚太东南（新加坡）</a-option>
                <a-option value="ap-tokyo">亚太东北（东京）</a-option>
                <a-option value="eu-frankfurt">欧洲地区（法兰克福）</a-option>
                <a-option value="na-ashburn">美国东部（弗吉尼亚）</a-option>
                <a-option value="na-siliconvalley">美国西部（硅谷）</a-option>
                <a-option value="sa-saopaulo">南美地区（圣保罗）</a-option>
              </a-select>
            </a-form-item>
          </a-col>
        </a-row>
        
        <a-row :gutter="16">
          <a-col :span="12">
            <a-form-item field="node_type" label="节点类型" validate-trigger="blur" required>
              <a-select v-model="batchAddForm.node_type" placeholder="请选择节点类型">
                <a-option value="scf">云函数</a-option>
                <a-option value="server">服务器</a-option>
              </a-select>
            </a-form-item>
          </a-col>
          <a-col :span="12">
            <a-form-item field="count" label="创建数量" validate-trigger="blur">
              <a-input-number 
                v-model="batchAddForm.count" 
                placeholder="请输入创建数量"
                :min="1"
                :max="50"
                style="width: 100%"
              />
              <template #extra>
                <div style="color: #86909c; font-size: 12px; margin-top: 4px">
                  每个地区每个命名空间最多支持50个云函数，系统将自动分配到不同的命名空间
                </div>
              </template>
            </a-form-item>
          </a-col>
        </a-row>

        <a-form-item field="supported_collectors" label="支持的采集器类型">
          <a-select v-model="batchAddForm.supported_collectors" placeholder="请选择支持的采集器" multiple>
            <a-option value="kline">K线数据</a-option>
            <a-option value="ticker">Ticker数据</a-option>
            <a-option value="orderbook">订单簿数据</a-option>
            <a-option value="trade">交易数据</a-option>
            <a-option value="news">新闻数据</a-option>
          </a-select>
        </a-form-item>

        <a-alert type="info" style="margin-bottom: 16px">
          <template #title>批量创建说明</template>
          <ul style="margin: 8px 0; padding-left: 20px">
            <li>系统将自动生成节点ID和分配命名空间</li>
            <li>每个命名空间最多支持50个函数，超过将自动分配到新的命名空间</li>
            <li>每个地区最多支持5个命名空间（总计250个函数）</li>
            <li>创建过程为串行执行，请耐心等待</li>
          </ul>
        </a-alert>

        <div v-if="batchAddProgress.show" style="margin-top: 16px; padding: 16px; background-color: #f5f7fa; border-radius: 4px;">
          <div style="margin-bottom: 12px; font-weight: 500; font-size: 16px; color: #1d2129;">
            创建进度：{{ batchAddProgress.current }} / {{ batchAddProgress.total }}
          </div>
          <!-- 自定义进度条 -->
          <div style="margin-bottom: 8px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
              <span style="font-size: 14px; color: #1d2129;">进度</span>
              <span style="font-size: 14px; color: #1d2129; font-weight: 500;">{{ addProgressPercent }}%</span>
            </div>
            <div style="width: 100%; height: 12px; background-color: #f2f3f5; border-radius: 6px; overflow: hidden;">
              <div
                style="height: 100%; background-color: #00b42a; border-radius: 6px; transition: width 0.3s ease;"
                :style="{ width: addProgressPercent + '%' }"
              ></div>
            </div>
          </div>
          <div v-if="batchAddProgress.isProcessing" style="margin-top: 12px; color: #4e5969; font-size: 14px;">
            <icon-loading spin style="margin-right: 4px;" />
            <span v-if="batchAddProgress.current === 0 || (batchAddProgress.success.length === 0 && batchAddProgress.errors.length === 0)">
              正在准备创建节点...
            </span>
            <span v-else>
              正在创建第 {{ batchAddProgress.current + 1 }} 个节点...
            </span>
          </div>
        </div>
        
        <a-alert v-if="batchAddProgress.show && !batchAddProgress.isProcessing" :type="batchAddProgress.type" style="margin-top: 16px">
          <template #title>
            创建完成：成功 {{ batchAddProgress.success.length }} 个，失败 {{ batchAddProgress.errors.length }} 个
          </template>
          <a-collapse v-if="batchAddProgress.success.length > 0 || batchAddProgress.errors.length > 0" 
            :default-active-key="batchAddProgress.errors.length > 0 ? ['errors'] : []"
            style="margin-top: 8px"
          >
            <a-collapse-item v-if="batchAddProgress.success.length > 0" key="success">
              <template #header>
                <span style="color: green">成功创建的节点 ({{ batchAddProgress.success.length }})</span>
              </template>
              <div v-for="node in batchAddProgress.success" :key="node.node_id" style="color: green; font-size: 12px; line-height: 1.5">
                {{ node.node_id }} ({{ node.namespace }})
              </div>
            </a-collapse-item>
            <a-collapse-item v-if="batchAddProgress.errors.length > 0" key="errors">
              <template #header>
                <span style="color: red">失败信息 ({{ batchAddProgress.errors.length }})</span>
              </template>
              <div v-for="error in batchAddProgress.errors" :key="error.index" style="color: red; font-size: 12px; line-height: 1.5">
                第{{ error.index + 1 }}个: {{ error.message }}
              </div>
            </a-collapse-item>
          </a-collapse>
        </a-alert>
      </a-form>
      
    </a-modal>

    <!-- 批量删除弹窗 -->
    <a-modal
      v-model:visible="batchDeleteVisible"
      title="批量删除云函数"
      width="700px"
      :ok-text="batchDeleteProgress.show && !batchDeleteProgress.isProcessing ? '关闭' : '确定删除'"
      :cancel-button-props="{ style: { display: batchDeleteProgress.show ? 'none' : 'inline-block' } }"
      :ok-loading="batchDeleteProgress.isProcessing"
      :ok-button-props="{ status: batchDeleteProgress.show ? 'normal' : 'danger' }"
      :closable="!batchDeleteProgress.isProcessing"
      :mask-closable="!batchDeleteProgress.isProcessing"
      :escape-to-close="!batchDeleteProgress.isProcessing"
      @before-ok="handleBatchDeleteBeforeOk"
      @cancel="batchDeleteVisible = false"
    >
      <div v-if="!batchDeleteProgress.show">
        <a-alert type="warning" style="margin-bottom: 16px">
          <template #title>删除警告</template>
          <div>您即将删除 <strong>{{ selectedKeys.length }}</strong> 个节点，删除后将无法恢复。</div>
          <div style="margin-top: 8px;">删除节点同时会删除对应的云函数资源，请谨慎操作。</div>
        </a-alert>
        
        <div style="margin-bottom: 8px; font-weight: 500;">即将删除的节点列表：</div>
        <div style="max-height: 300px; overflow-y: auto; border: 1px solid #e8e8e8; border-radius: 4px; padding: 8px;">
          <a-table 
            :data="selectedNodesForDelete" 
            :show-header="false"
            :pagination="false"
            size="small"
          >
            <template #columns>
              <a-table-column>
                <template #cell="{ record }">
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                      <div style="font-weight: 500;">{{ record.node_id }}</div>
                      <div style="font-size: 12px; color: #86909c;">
                        {{ getRegionName(record.region) }} | {{ record.node_type === 'scf' ? '云函数' : '服务器' }}
                      </div>
                    </div>
                    <a-tag size="small" :color="record.status === 1 ? 'green' : 'gray'">
                      {{ record.status === 1 ? '在线' : '离线' }}
                    </a-tag>
                  </div>
                </template>
              </a-table-column>
            </template>
          </a-table>
        </div>
      </div>
      
      <div v-else>
        <div style="padding: 16px; background-color: #f5f7fa; border-radius: 4px;">
          <div style="margin-bottom: 12px; font-weight: 500; font-size: 16px; color: #1d2129;">
            删除进度：{{ batchDeleteProgress.current }} / {{ batchDeleteProgress.total }}
          </div>
          <!-- 自定义进度条 -->
          <div style="margin-bottom: 8px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
              <span style="font-size: 14px; color: #1d2129;">进度</span>
              <span style="font-size: 14px; color: #1d2129; font-weight: 500;">{{ deleteProgressPercent }}%</span>
            </div>
            <div style="width: 100%; height: 12px; background-color: #f2f3f5; border-radius: 6px; overflow: hidden;">
              <div
                style="height: 100%; background-color: #f53f3f; border-radius: 6px; transition: width 0.3s ease;"
                :style="{ width: deleteProgressPercent + '%' }"
              ></div>
            </div>
          </div>
          <div v-if="batchDeleteProgress.isProcessing" style="margin-top: 12px; color: #4e5969; font-size: 14px;">
            <icon-loading spin style="margin-right: 4px;" />
            正在删除第 {{ batchDeleteProgress.current + 1 }} 个节点...
          </div>
        </div>
        
        <a-alert v-if="!batchDeleteProgress.isProcessing" :type="batchDeleteProgress.type" style="margin-top: 16px">
          <template #title>
            删除完成：成功 {{ batchDeleteProgress.success.length }} 个，失败 {{ batchDeleteProgress.errors.length }} 个
          </template>
          <a-collapse v-if="batchDeleteProgress.success.length > 0 || batchDeleteProgress.errors.length > 0" 
            :default-active-key="batchDeleteProgress.errors.length > 0 ? ['errors'] : []"
            style="margin-top: 8px"
          >
            <a-collapse-item v-if="batchDeleteProgress.success.length > 0" key="success">
              <template #header>
                <span style="color: green">成功删除的节点 ({{ batchDeleteProgress.success.length }})</span>
              </template>
              <div v-for="node in batchDeleteProgress.success" :key="node.node_id" style="color: green; font-size: 12px; line-height: 1.5">
                {{ node.node_id }}
              </div>
            </a-collapse-item>
            <a-collapse-item v-if="batchDeleteProgress.errors.length > 0" key="errors">
              <template #header>
                <span style="color: red">删除失败的节点 ({{ batchDeleteProgress.errors.length }})</span>
              </template>
              <div v-for="error in batchDeleteProgress.errors" :key="error.node_id" style="color: red; font-size: 12px; line-height: 1.5; margin-bottom: 4px;">
                <strong>{{ error.node_id }}:</strong> {{ error.message }}
              </div>
            </a-collapse-item>
          </a-collapse>
        </a-alert>
      </div>
    </a-modal>

  </div>
</template>

<script setup lang="ts">
import { ref, reactive, computed, onMounted, nextTick } from 'vue';
import { Message, Modal } from '@arco-design/web-vue';
import {
  IconCheckCircle,
  IconExclamationCircle,
  IconCheck,
  IconClose
} from '@arco-design/web-vue/es/icon';
import service from '@/api/index';
import { 
  getCloudAccountList, 
  createCloudAccount, 
  updateCloudAccount, 
  deleteCloudAccount,
  type CloudAccount 
} from '@/api/cloud-account';

interface CloudFunction {
  node_id: string;
  cloud_account_id: string;
  namespace: string;
  node_type: string;
  region: string;
  ip_address: string;
  supported_collectors: string;
  capacity: string;
  current_load: string;
  status: string;
  last_heartbeat: string;
  metadata: string;
}

const loading = ref(false);
const allFunctionList = ref<CloudFunction[]>([]); // 存储所有数据
const functionList = ref<CloudFunction[]>([]); // 存储当前页数据
const selectedKeys = ref<string[]>([]);
const open = ref(false);
const title = ref('新增节点');
const formRef = ref();
const supportedCollectorsList = ref<string[]>([]);
const nodeDetailVisible = ref(false);
const nodeDetail = ref<Partial<CloudFunction>>({});

// 云账户管理相关
const cloudAccountVisible = ref(false);
const cloudAccountList = ref<CloudAccount[]>([]);
const cloudAccountOptions = ref<CloudAccount[]>([]);
const cloudAccountLoading = ref(false);
const cloudAccountEditVisible = ref(false);
const cloudAccountEditTitle = ref('新增云账户');
const cloudAccountFormRef = ref();
const cloudAccountForm = ref<Partial<CloudAccount>>({
  account_id: '',
  account_name: '',
  provider: 'tencent',
  secret_id: '',
  secret_key: '',
  extra_config: '{}'
});
const cloudAccountRules = {
  account_id: [{ required: true, message: '请输入云账户ID' }],
  account_name: [{ required: true, message: '请输入账户名称' }],
  provider: [{ required: true, message: '请选择云厂商' }],
  secret_id: [{ required: true, message: '请输入密钥ID' }],
  secret_key: [
    { 
      required: true, 
      message: '请输入密钥',
      validator: (value: string | undefined, callback: (error?: string) => void) => {
        if (cloudAccountEditTitle.value === '新增云账户' && !value) {
          callback('请输入密钥');
        } else {
          callback();
        }
      }
    }
  ]
};

// 云函数部署相关
const deployVisible = ref(false);
const deployFormRef = ref();
const deployForm = ref({
  node_id: '',
  namespace: '',
  region: '',
  cloud_account_id: '',
  zip_file: null as File | null,
  description: ''
});
const deployRules = {
  zip_file: [
    { 
      required: true, 
      message: '请选择要部署的ZIP文件',
      validator: (value: any, callback: (error?: string) => void) => {
        if (!deployForm.value.zip_file) {
          callback('请选择要部署的ZIP文件');
        } else {
          callback();
        }
      }
    }
  ]
};
const fileList = ref<any[]>([]);

// 批量部署相关
const batchDeployVisible = ref(false);
const batchDeployFormRef = ref();
const batchDeployForm = ref({
  zip_file: null as File | null,
  description: ''
});
const batchDeployRules = {
  zip_file: [
    {
      required: true,
      message: '请选择要部署的ZIP文件',
      validator: (value: any, callback: (error?: string) => void) => {
        if (!batchDeployForm.value.zip_file) {
          callback('请选择要部署的ZIP文件');
        } else {
          callback();
        }
      }
    }
  ]
};
