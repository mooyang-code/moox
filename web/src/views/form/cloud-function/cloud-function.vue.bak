    cloudAccountId: '',
    namespace: '',
    region: null,
    nodeType: null,
    status: null
  };
  getFunctionList();
};

const getFunctionList = async () => {
  loading.value = true;
  try {
    const params: any = {};

    if (form.value.cloudAccountId) {
      params.cloud_account_id = form.value.cloudAccountId;
    }
    if (form.value.namespace) {
      params.namespace = form.value.namespace;
    }
    if (form.value.region) {
      params.region = form.value.region;
    }
    if (form.value.nodeType) {
      params.node_type = form.value.nodeType;
    }
    if (form.value.status !== null) {
      params.status = form.value.status;
    }

    const response = await service.post('/gateway/collector/ListNodes', params, {
      headers: {
        'app_id': 'moox_frontend',
        'app_key': '2521e0d21b6be0347b72bca93904a0dd'
      }
    });

    // 处理后端返回的数据
    if (response.code === 200) {
      allFunctionList.value = response.data || [];
      pagination.value.total = allFunctionList.value.length;

      // 重置到第一页并更新当前页数据
      pagination.value.current = 1;
      updateCurrentPageData();

      console.log(`获取到${allFunctionList.value.length}条数据，当前显示第${pagination.value.current}页`);
    } else {
      Message.error(response.message || '获取节点列表失败');
    }
  } catch (error) {
    console.error('获取云函数列表失败:', error);
    Message.error('获取云函数列表失败');
  } finally {
    loading.value = false;
  }
};

const onAdd = () => {
  title.value = '新增节点';
  addForm.value = {
    cloud_account_id: '',
    node_type: 'scf',
    region: 'ap-guangzhou',
    ip_address: '',
    supported_collectors: '["kline"]',
    capacity: '{}',
    current_load: '{}',
    metadata: '{}',
    status: '1'
  };
  supportedCollectorsList.value = ['kline'];
  open.value = true;
};

const onUpdate = (record: CloudFunction) => {
  title.value = '修改节点';
  addForm.value = { ...record };
  
  // 解析 supported_collectors
  try {
    supportedCollectorsList.value = JSON.parse(record.supported_collectors || '[]');
  } catch {
    supportedCollectorsList.value = [];
  }
  
  open.value = true;
};

const afterClose = () => {
  formRef.value?.clearValidate();
  open.value = false;
};

const handleOk = async () => {
  const valid = await formRef.value?.validate();
  if (!valid) {
    try {
      // 将选中的采集器类型转换为JSON字符串
      addForm.value.supported_collectors = JSON.stringify(supportedCollectorsList.value);
      
      // 验证JSON格式
      JSON.parse(addForm.value.capacity || '{}');
      JSON.parse(addForm.value.metadata || '{}');
      
      // 确保 status 是字符串
      const requestData = {
        ...addForm.value,
        status: String(addForm.value.status)
      };
      
      const endpoint = title.value === '新增节点' ? '/gateway/collector/RegisterNode' : '/gateway/collector/UpdateNode';
      const response = await service.post(endpoint, requestData, {
        headers: {
          'app_id': 'moox_frontend',
          'app_key': '2521e0d21b6be0347b72bca93904a0dd'
        }
      });

      if (response.code === 200) {
        Message.success(title.value + '成功');
        if (title.value === '新增节点' && response.data) {
          const result = Array.isArray(response.data) ? response.data[0] : response.data;
          if (result.node_id && result.namespace) {
            Message.info(`分配的节点ID: ${result.node_id}, 命名空间: ${result.namespace}`);
          }
        }
        open.value = false;
        getFunctionList();
      } else {
        Message.error(response.message || title.value + '失败');
      }
    } catch (error) {
      if (error instanceof SyntaxError) {
        Message.error('JSON格式错误，请检查输入');
      } else {
        console.error(title.value + '失败:', error);
        Message.error(title.value + '失败');
      }
    }
  }
};

const handleDelete = async (record: CloudFunction) => {
  try {
    const response = await service.post('/gateway/collector/DeleteNode', { node_id: record.node_id }, {
      headers: {
        'app_id': 'moox_frontend',
        'app_key': '2521e0d21b6be0347b72bca93904a0dd'
      }
    });

    if (response.code === 200) {
      Message.success('删除成功');
      getFunctionList();
    } else {
      Message.error(response.message || '删除失败');
    }
  } catch (error) {
    console.error('删除失败:', error);
    Message.error('删除失败');
  }
};

const batchDelete = () => {
  if (selectedKeys.value.length === 0) {
    Message.warning('请选择要删除的节点');
    return;
  }
  
  // 重置进度
  batchDeleteProgress.value = {
    show: false,
    type: 'info',
    current: 0,
    total: selectedKeys.value.length,
    isProcessing: false,
    progressStatus: 'normal',
    success: [],
    errors: []
  };
  
  // 显示确认弹窗
  batchDeleteVisible.value = true;
};

// 处理批量删除弹窗的确定按钮 - before-ok事件
const handleBatchDeleteBeforeOk = async (done: (closed: boolean) => void) => {
  console.log('批量删除弹窗确定按钮被点击');
  console.log('当前删除进度状态:', {
    show: batchDeleteProgress.show,
    isProcessing: batchDeleteProgress.isProcessing
  });

  // 如果已经显示进度并且处理完成，则关闭弹窗
  if (batchDeleteProgress.show && !batchDeleteProgress.isProcessing) {
    console.log('关闭删除弹窗');
    closeBatchDeleteModal();
    done(true); // 允许关闭
  } else {
    // 否则执行删除操作
    console.log('执行删除操作');
    // 阻止默认的关闭行为
    done(false); // 阻止关闭
    await executeBatchDelete();
  }
};

// 关闭批量删除弹窗
const closeBatchDeleteModal = () => {
  batchDeleteVisible.value = false;
  // 清空选中项
  selectedKeys.value = [];
  // 重置进度
  batchDeleteProgress.show = false;
  batchDeleteProgress.type = 'info';
  batchDeleteProgress.current = 0;
  batchDeleteProgress.total = 0;
  batchDeleteProgress.isProcessing = false;
  batchDeleteProgress.progressStatus = 'normal';
  batchDeleteProgress.success = [];
  batchDeleteProgress.errors = [];
};

// 执行批量删除
const executeBatchDelete = async () => {
  console.log('开始批量删除，选中节点数量:', selectedKeys.value.length);

  // 显示进度
  batchDeleteProgress.show = true;
  batchDeleteProgress.type = 'info';
  batchDeleteProgress.current = 0;
  batchDeleteProgress.total = selectedKeys.value.length;
  batchDeleteProgress.isProcessing = true;
  batchDeleteProgress.progressStatus = 'normal';
  batchDeleteProgress.success = [];
  batchDeleteProgress.errors = [];

  console.log('删除进度条状态已设置:', batchDeleteProgress);

  // 强制更新视图
  await nextTick();

  // 添加小延迟确保UI更新
  await new Promise(resolve => setTimeout(resolve, 100));
  
  // 串行删除节点
  for (let i = 0; i < selectedKeys.value.length; i++) {
    const nodeId = selectedKeys.value[i];

    try {
      const response = await service.post('/gateway/collector/DeleteNode', { node_id: nodeId }, {
        headers: {
          'app_id': 'moox_frontend',
          'app_key': '2521e0d21b6be0347b72bca93904a0dd'
        }
      });

      if (response.code === 200) {
        batchDeleteProgress.success.push({ node_id: nodeId });
      } else {
        batchDeleteProgress.errors.push({
          node_id: nodeId,
          message: response.message || '删除失败'
        });
      }
    } catch (error) {
      console.error(`删除节点 ${nodeId} 失败:`, error);
      batchDeleteProgress.errors.push({
        node_id: nodeId,
        message: '网络错误或服务异常'
      });
    }

    // 更新进度
    batchDeleteProgress.current = i + 1;
    console.log(`完成第 ${i + 1} 个删除请求，进度: ${batchDeleteProgress.current}/${batchDeleteProgress.total}`);

    // 强制UI更新
    await nextTick();

    // 更新进度类型
    if (batchDeleteProgress.errors.length > 0) {
      batchDeleteProgress.type = 'warning';
      batchDeleteProgress.progressStatus = 'danger';
    }

    // 添加延迟，让用户看到进度变化
    console.log(`等待延迟，当前删除进度: ${batchDeleteProgress.current}/${batchDeleteProgress.total}`);
    if (i < selectedKeys.value.length - 1) {
      await new Promise(resolve => setTimeout(resolve, 500)); // 500ms让用户能看到进度变化
    } else {
      // 最后一个请求完成后也等待一下
      await new Promise(resolve => setTimeout(resolve, 200));
    }
    console.log(`延迟结束，继续下一个删除请求`);

    // 在延迟前再次强制更新
    await nextTick();
  }
  
  // 设置最终进度
  batchDeleteProgress.current = selectedKeys.value.length;
  batchDeleteProgress.isProcessing = false;

  console.log('删除完成，等待3秒后显示结果...');

  // 等待3秒让用户看到进度条完成
  await new Promise(resolve => setTimeout(resolve, 3000));

  if (batchDeleteProgress.errors.length === 0) {
    batchDeleteProgress.type = 'success';
    batchDeleteProgress.progressStatus = 'success';
    Message.success(`成功删除 ${batchDeleteProgress.success.length} 个节点`);
  } else {
    batchDeleteProgress.type = 'error';
    const successCount = batchDeleteProgress.success.length;
    Message.warning(`删除完成：成功 ${successCount} 个，失败 ${batchDeleteProgress.errors.length} 个`);
  }

  console.log('显示删除结果完成，等待2秒后可以关闭弹窗');

  // 再等待2秒让用户看到结果
  await new Promise(resolve => setTimeout(resolve, 2000));

  console.log('现在可以关闭删除弹窗了');

  // 刷新列表
  setTimeout(() => {
    getFunctionList();
  }, 1000);
};


