};

const getCloudAccounts = async () => {
  cloudAccountLoading.value = true;
  try {
    cloudAccountList.value = await getCloudAccountList();
    cloudAccountOptions.value = cloudAccountList.value;
  } catch (error) {
    console.error('获取云账户列表失败:', error);
    Message.error('获取云账户列表失败');
  } finally {
    cloudAccountLoading.value = false;
  }
};

const onAddCloudAccount = () => {
  cloudAccountEditTitle.value = '新增云账户';
  cloudAccountForm.value = {
    account_id: '',
    account_name: '',
    provider: 'tencent',
    secret_id: '',
    secret_key: '',
    extra_config: '{}'
  };
  cloudAccountEditVisible.value = true;
};

const onEditCloudAccount = (record: CloudAccount) => {
  cloudAccountEditTitle.value = '编辑云账户';
  cloudAccountForm.value = {
    ...record,
    secret_key: '' // 编辑时不显示原密钥
  };
  cloudAccountEditVisible.value = true;
};

const handleCloudAccountSubmit = async () => {
  const valid = await cloudAccountFormRef.value?.validate();
  if (!valid) {
    try {
      // 验证额外配置的JSON格式
      if (cloudAccountForm.value.extra_config) {
        JSON.parse(cloudAccountForm.value.extra_config);
      }
      
      if (cloudAccountEditTitle.value === '新增云账户') {
        await createCloudAccount(cloudAccountForm.value as CloudAccount);
        Message.success('创建云账户成功');
      } else {
        // 编辑时，如果密钥为空，则不更新密钥
        const updateData = { ...cloudAccountForm.value };
        if (!updateData.secret_key) {
          delete updateData.secret_key;
        }
        await updateCloudAccount(updateData as CloudAccount);
        Message.success('更新云账户成功');
      }
      
      cloudAccountEditVisible.value = false;
      getCloudAccounts();
    } catch (error) {
      if (error instanceof SyntaxError) {
        Message.error('额外配置必须是有效的JSON格式');
      } else {
        console.error('操作失败:', error);
        Message.error(cloudAccountEditTitle.value + '失败');
      }
    }
  }
};

const handleDeleteCloudAccount = async (record: CloudAccount) => {
  try {
    await deleteCloudAccount(record.account_id);
    Message.success('删除云账户成功');
    getCloudAccounts();
  } catch (error) {
    console.error('删除云账户失败:', error);
    Message.error('删除云账户失败');
  }
};

