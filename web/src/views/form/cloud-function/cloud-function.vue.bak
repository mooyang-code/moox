// 云函数部署相关方法
const onDeploy = (record: CloudFunction) => {
  deployForm.value = {
    node_id: record.node_id,
    namespace: record.namespace,
    region: record.region,
    cloud_account_id: record.cloud_account_id,
    zip_file: null,
    description: ''
  };
  fileList.value = [];
  deployVisible.value = true;
};

const handleFileChange = (fileItem: any, fileList: any[]) => {
  if (fileList.length > 0) {
    const file = fileList[0];
    if (file.file) {
      // 检查文件大小（100MB限制）
      if (file.file.size > 100 * 1024 * 1024) {
        Message.error('文件大小不能超过100MB');
        fileList.splice(0, 1);
        return;
      }
      deployForm.value.zip_file = file.file;
    }
  } else {
    deployForm.value.zip_file = null;
  }
};

const handleDeploySubmit = async () => {
  const valid = await deployFormRef.value?.validate();
  if (!valid) {
    if (!deployForm.value.zip_file) {
      Message.error('请选择要部署的ZIP文件');
      return;
    }

    try {
      // 将文件转换为base64
      const fileToBase64 = (file: File): Promise<string> => {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.readAsDataURL(file);
          reader.onload = () => {
            // 移除 data:application/zip;base64, 前缀
            const base64 = (reader.result as string).split(',')[1];
            resolve(base64);
          };
          reader.onerror = error => reject(error);
        });
      };
      
      const zipFileBase64 = await fileToBase64(deployForm.value.zip_file);
      
      // 使用网关接口
      const response = await service.post('/gateway/collector/UploadFunction', {
        node_id: deployForm.value.node_id,
        zip_file_base64: zipFileBase64,
        file_name: deployForm.value.zip_file.name
      }, {
        headers: {
          'app_id': 'moox_frontend',
          'app_key': '2521e0d21b6be0347b72bca93904a0dd'
        }
      });

      if (response.code === 200) {
        Message.success('云函数部署任务已提交，正在后台处理中');
        deployVisible.value = false;
        
        // 显示部署信息
        if (response.data) {
          const info = `节点: ${response.data.node_id}\n文件: ${response.data.file_name} (${(response.data.file_size / 1024).toFixed(2)}KB)`;
          Modal.info({
            title: '部署任务已提交',
            content: info,
            okText: '确定'
          });
        }
      } else {
        Message.error(response.message || '部署失败');
      }
    } catch (error) {
      console.error('部署云函数失败:', error);
      Message.error('部署云函数失败，请稍后重试');
    }
  }
};

// 批量部署相关方法
const batchDeploy = () => {
  if (selectedKeys.value.length === 0) {
    Message.warning('请选择要部署的节点');
    return;
  }
  
  // 筛选出云函数类型的节点
  selectedNodesForDeploy.value = allFunctionList.value.filter(node =>
    selectedKeys.value.includes(node.node_id) && node.node_type === 'scf'
  );
  
  if (selectedNodesForDeploy.value.length === 0) {
    Message.warning('所选节点中没有云函数类型的节点');
    return;
  }
  
  // 重置表单和进度
  batchDeployForm.value = {
    zip_file: null,
    description: ''
  };
  batchFileList.value = [];
  batchDeployProgress.value = {
    show: false,
    type: 'info',
    current: 0,
    total: 0,
    isProcessing: false,
    progressStatus: 'normal',
    success: [],
    errors: []
  };
  
  // 清除表单验证状态
  nextTick(() => {
    batchDeployFormRef.value?.clearValidate();
  });
  
  batchDeployVisible.value = true;
};

const handleBatchFileChange = (fileItem: any, fileList: any) => {
  console.log('批量部署文件变化:', { fileItem, fileList });
  console.log('fileItem 结构:', fileItem);
  console.log('fileList 结构:', fileList);

  // 根据控制台输出分析：
  // fileItem 是数组: Proxy(Array) {0: Proxy(Object)}
  // fileList 是对象: Proxy(Object) {uid: '...', file: File, name: '...', ...}

  // 先处理 fileItem 数组
  if (Array.isArray(fileItem)) {
    batchFileList.value = fileItem;
    console.log('设置 batchFileList.value =', fileItem);

    if (fileItem.length > 0) {
      const file = fileItem[0];
      console.log('从 fileItem 数组中取出的文件对象:', file);

      // 尝试不同的文件对象结构
      let actualFile = null;
      if (file.file) {
        actualFile = file.file;
      } else if (file.originFile) {
        actualFile = file.originFile;
      } else if (file instanceof File) {
        actualFile = file;
      }

      console.log('从 fileItem 中提取的实际文件对象:', actualFile);

      if (actualFile) {
        // 检查文件大小（100MB限制）
        if (actualFile.size > 100 * 1024 * 1024) {
          Message.error('文件大小不能超过100MB');
          batchFileList.value = [];
          batchDeployForm.value.zip_file = null;
          return;
        }
        batchDeployForm.value.zip_file = actualFile;
        console.log('批量部署文件已设置:', batchDeployForm.value.zip_file?.name);
        // 手动触发表单验证
        nextTick(() => {
          batchDeployFormRef.value?.validateField('zip_file');
        });
        return;
      }
    }
  }

  // 如果 fileItem 处理失败，尝试处理 fileList
  if (fileList && fileList.file) {
    console.log('尝试从 fileList 中提取文件:', fileList.file);
    batchFileList.value = [fileList];

    // 检查文件大小（100MB限制）
    if (fileList.file.size > 100 * 1024 * 1024) {
      Message.error('文件大小不能超过100MB');
      batchFileList.value = [];
      batchDeployForm.value.zip_file = null;
      return;
    }

    batchDeployForm.value.zip_file = fileList.file;
    console.log('从 fileList 设置批量部署文件:', batchDeployForm.value.zip_file?.name);
    // 手动触发表单验证
    nextTick(() => {
      batchDeployFormRef.value?.validateField('zip_file');
    });
  } else {
    batchDeployForm.value.zip_file = null;
    batchFileList.value = [];
    console.log('批量部署文件已清空');
  }
};

// 处理批量部署弹窗的确定按钮 - before-ok事件
const handleBatchDeployBeforeOk = async (done: (closed: boolean) => void) => {
  console.log('批量部署弹窗确定按钮被点击');
  console.log('当前进度状态:', {
    show: batchDeployProgress.show,
    isProcessing: batchDeployProgress.isProcessing
  });

  // 如果已经显示进度并且处理完成，则关闭弹窗
  if (batchDeployProgress.show && !batchDeployProgress.isProcessing) {
    console.log('关闭弹窗');
    closeBatchDeployModal();
    done(true); // 允许关闭
  } else {
    // 否则执行部署操作
    console.log('执行部署操作');
    // 阻止默认的关闭行为
    done(false); // 阻止关闭
    await handleBatchDeploySubmit();
  }
};

// 关闭批量部署弹窗
const closeBatchDeployModal = () => {
  batchDeployVisible.value = false;
  // 清空选中项和文件
  selectedKeys.value = [];
  batchFileList.value = [];
  batchDeployForm.value = {
    zip_file: null,
    description: ''
  };
  // 重置进度
  batchDeployProgress.show = false;
  batchDeployProgress.type = 'info';
  batchDeployProgress.current = 0;
  batchDeployProgress.total = 0;
  batchDeployProgress.isProcessing = false;
  batchDeployProgress.progressStatus = 'normal';
  batchDeployProgress.success = [];
  batchDeployProgress.errors = [];
};

const handleBatchDeploySubmit = async () => {
  console.log('开始批量部署提交...');
  console.log('当前选中的节点数量:', selectedNodesForDeploy.value.length);
  console.log('当前文件:', batchDeployForm.value.zip_file?.name);
  console.log('batchDeployForm.value:', batchDeployForm.value);

  // 直接检查是否选择了文件
  if (!batchDeployForm.value.zip_file) {
    console.log('文件检查失败: 没有选择文件');
    Message.error('请选择要部署的ZIP文件');
    return;
  }

  console.log('文件检查成功，开始显示进度条...');

  // 显示进度
  console.log('设置进度条状态...');
  batchDeployProgress.show = true;
  batchDeployProgress.type = 'info';
  batchDeployProgress.current = 0;
  batchDeployProgress.total = selectedNodesForDeploy.value.length;
  batchDeployProgress.isProcessing = true;
  batchDeployProgress.progressStatus = 'normal';
  batchDeployProgress.success = [];
  batchDeployProgress.errors = [];
  console.log('进度条状态已设置:', batchDeployProgress);

  // 强制更新视图
  console.log('强制更新视图...');
  await nextTick();
  console.log('视图更新完成');

  // 添加小延迟确保UI更新
  console.log('等待UI更新...');
  await new Promise(resolve => setTimeout(resolve, 100));
  console.log('UI更新等待完成');

  // 不使用假进度条，在实际请求中更新进度
  console.log('开始实际部署，进度将在每个请求完成后更新...');
  
  // 先将文件转换为base64
  console.log('开始文件转换...');
  const fileToBase64 = (file: File): Promise<string> => {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = () => {
        // 移除 data:application/zip;base64, 前缀
        const base64 = (reader.result as string).split(',')[1];
        resolve(base64);
      };
      reader.onerror = error => reject(error);
    });
  };

  let zipFileBase64: string;
  try {
    console.log('转换文件为base64...');
    zipFileBase64 = await fileToBase64(batchDeployForm.value.zip_file);
    console.log('文件转换成功，base64长度:', zipFileBase64.length);
  } catch (error) {
    console.error('文件转换失败:', error);
    Message.error('文件转换失败');
    batchDeployProgress.isProcessing = false;
    return;
  }
  
  // 串行部署到每个节点
  for (let i = 0; i < selectedNodesForDeploy.value.length; i++) {
    const node = selectedNodesForDeploy.value[i];
    
    try {
      // 使用网关接口
      const response = await service.post('/gateway/collector/UploadFunction', {
        node_id: node.node_id,
        zip_file_base64: zipFileBase64,
        file_name: batchDeployForm.value.zip_file.name
      }, {
        headers: {
          'app_id': 'moox_frontend',
          'app_key': '2521e0d21b6be0347b72bca93904a0dd'
        }
      });

      if (response.code === 200) {
        batchDeployProgress.success.push({
          node_id: node.node_id,
          namespace: node.namespace,
          region: node.region
        });
      } else {
        batchDeployProgress.errors.push({
          node_id: node.node_id,
          message: response.message || '部署失败'
        });
      }
    } catch (error) {
      console.error(`部署到节点 ${node.node_id} 失败:`, error);
      batchDeployProgress.errors.push({
        node_id: node.node_id,
        message: '网络错误或服务异常'
      });
    }

    // 更新进度
    batchDeployProgress.current = i + 1;
    console.log(`完成第 ${i + 1} 个请求，进度: ${batchDeployProgress.current}/${batchDeployProgress.total}`);

    // 强制UI更新
    await nextTick();

    // 更新进度类型
    if (batchDeployProgress.errors.length > 0) {
      batchDeployProgress.type = 'warning';
      batchDeployProgress.progressStatus = 'danger';
    }

    // 添加延迟，让用户看到进度变化
    console.log(`等待延迟，当前进度: ${batchDeployProgress.current}/${batchDeployProgress.total}`);
    if (i < selectedNodesForDeploy.value.length - 1) {
      await new Promise(resolve => setTimeout(resolve, 1000)); // 增加到1秒让用户能清楚看到进度变化
    } else {
      // 最后一个请求完成后也等待一下
      await new Promise(resolve => setTimeout(resolve, 500));
    }
    console.log(`延迟结束，继续下一个请求`);

    // 在延迟前再次强制更新
    await nextTick();
  }
  
  // 设置最终进度
  batchDeployProgress.current = selectedNodesForDeploy.value.length;
  batchDeployProgress.isProcessing = false;

  console.log('部署完成，等待3秒后显示结果...');

  // 等待3秒让用户看到进度条完成
  await new Promise(resolve => setTimeout(resolve, 3000));

  if (batchDeployProgress.errors.length === 0) {
    batchDeployProgress.type = 'success';
    batchDeployProgress.progressStatus = 'success';
    Message.success(`成功部署到所有 ${batchDeployProgress.success.length} 个节点，更新任务已加入队列`);
  } else {
    batchDeployProgress.type = 'error';
    const successCount = batchDeployProgress.success.length;
    Message.warning(`部署完成：成功 ${successCount} 个，失败 ${batchDeployProgress.errors.length} 个`);
  }

  console.log('显示结果完成，等待2秒后可以关闭弹窗');

  // 再等待2秒让用户看到结果
  await new Promise(resolve => setTimeout(resolve, 2000));

  console.log('现在可以关闭弹窗了');

  // 刷新列表
  setTimeout(() => {
    getFunctionList();
  }, 1000);
};

// 关闭批量新增弹窗
const closeBatchAddModal = () => {
  batchAddVisible.value = false;
  // 重置进度
  batchAddProgress.show = false;
  batchAddProgress.type = 'info';
  batchAddProgress.current = 0;
  batchAddProgress.total = 0;
  batchAddProgress.success = [];
  batchAddProgress.errors = [];
  batchAddProgress.isProcessing = false;
  batchAddProgress.progressStatus = 'normal';
};

// 处理批量新增弹窗的确定按钮 - before-ok事件
const handleBatchAddBeforeOk = async (done: (closed: boolean) => void) => {
  console.log('批量新增弹窗确定按钮被点击');
  console.log('当前新增进度状态:', {
    show: batchAddProgress.show,
    isProcessing: batchAddProgress.isProcessing
  });

  // 如果已经显示进度并且处理完成，则关闭弹窗
  if (batchAddProgress.show && !batchAddProgress.isProcessing) {
    console.log('关闭新增弹窗');
    closeBatchAddModal();
    done(true); // 允许关闭
  } else {
    // 否则执行提交操作
    console.log('执行新增操作');
    // 阻止默认的关闭行为
    done(false); // 阻止关闭
    await handleBatchAddSubmit();
  }
};

// 批量新增相关方法
const onBatchAdd = () => {
  // 重置表单
  batchAddForm.value = {
    cloud_account_id: '',
    region: 'ap-guangzhou',
    node_type: 'scf',
    count: 1,
    supported_collectors: ['kline']
  };
  batchAddProgress.value = {
    show: false,
    type: 'info',
    current: 0,
    total: 0,
    success: [],
    errors: [],
    isProcessing: false,
    progressStatus: 'normal'
  };
  batchAddVisible.value = true;
};

const handleBatchAddSubmit = async () => {
  // 先检查云账户是否选择
  if (!batchAddForm.value.cloud_account_id) {
    Message.error('请选择云账户！云账户为必填项');
    return;
  }
  
  const valid = await batchAddFormRef.value?.validate();
  if (!valid) {
    // 直接执行批量创建
    await executeBatchAdd();
  }
};

// 通用的假进度条函数
const createFakeProgress = (total: number, progressRef: any) => {
  let fakeProgress = 0;

  // 根据数量计算进度速度
  // 数量越多，进度越慢
  const calculateInterval = () => {
    if (total <= 5) return 200;      // 5个以内，200ms更新一次
    if (total <= 10) return 300;     // 10个以内，300ms更新一次
    if (total <= 20) return 400;     // 20个以内，400ms更新一次
    if (total <= 50) return 500;     // 50个以内，500ms更新一次
    return 600;                       // 超过50个，600ms更新一次
  };

  const calculateIncrement = () => {
    if (total <= 5) return 0.15;     // 每次增加15%
    if (total <= 10) return 0.10;    // 每次增加10%
    if (total <= 20) return 0.08;    // 每次增加8%
    if (total <= 50) return 0.05;    // 每次增加5%
    return 0.03;                      // 每次增加3%
  };

  const interval = calculateInterval();
  const incrementRate = calculateIncrement();

  return setInterval(() => {
    // 假进度最多到90%
    if (fakeProgress < 0.9) {
      fakeProgress = Math.min(fakeProgress + incrementRate, 0.9);
      progressRef.value.current = Math.floor(fakeProgress * total);
    }
  }, interval);
};

// 批量部署专用的假进度条函数 - 根据实际请求速度
const createBatchDeployFakeProgress = (total: number, progressRef: any) => {
  console.log('创建假进度条，总数:', total, '每个请求间隔300ms');
  let currentIndex = 0;

  return setInterval(() => {
    if (currentIndex < total) {
      currentIndex++;
      progressRef.current = Math.min(currentIndex, total); // 确保不超过总数
      console.log('假进度条更新:', currentIndex, '/', total, '百分比:', Math.floor((currentIndex / total) * 100) + '%');
    }
  }, 300); // 每300ms更新一次，对应一个请求
};

const executeBatchAdd = async () => {
  console.log('开始批量新增，创建数量:', batchAddForm.value.count);

  // 显示进度
  batchAddProgress.show = true;
  batchAddProgress.type = 'info';
  batchAddProgress.current = 0;
  batchAddProgress.total = batchAddForm.value.count;
  batchAddProgress.success = [];
  batchAddProgress.errors = [];
  batchAddProgress.isProcessing = true;
  batchAddProgress.progressStatus = 'normal';

  console.log('新增进度条状态已设置:', batchAddProgress);

  // 强制更新视图
  await nextTick();

  // 添加小延迟确保UI更新
  await new Promise(resolve => setTimeout(resolve, 100));
  
  // 准备基础数据
  const baseData = {
    cloud_account_id: batchAddForm.value.cloud_account_id,
    node_type: batchAddForm.value.node_type,
    region: batchAddForm.value.region,
    supported_collectors: JSON.stringify(batchAddForm.value.supported_collectors || ['kline']),
    capacity: '{}',
    current_load: '{}',
    metadata: '{}',
    status: '1'
  };

  // 串行创建节点
  for (let i = 0; i < batchAddForm.value.count; i++) {
    // 生成唯一的节点ID
    const nodeId = `DataCollector-${Date.now()}-${i}`;
    const namespace = `${batchAddForm.value.region}-01`;
    
    const nodeData = {
      ...baseData,
      node_id: nodeId,
      namespace: namespace,
      version: '1.0.0',
      collector_version: '1.0.0',
      function_name: `scf-${nodeId}`,
      runtime: 'Go1',
      description: batchAddForm.value.description || `批量创建的云函数节点 ${i + 1}`
    };
    
    try {
      const response = await service.post('/gateway/collector/RegisterNode', nodeData, {
        headers: {
          'app_id': 'moox_frontend',
          'app_key': '2521e0d21b6be0347b72bca93904a0dd'
        }
      });
      
      if (response.code === 200) {
        const result = Array.isArray(response.data) ? response.data[0] : response.data;
        if (result.node_id && result.namespace) {
          batchAddProgress.success.push({
            node_id: result.node_id,
            namespace: result.namespace
          });
        }
      } else {
        batchAddProgress.errors.push({
          index: i,
          message: response.message || '创建失败'
        });
      }
    } catch (error) {
      console.error(`创建第 ${i + 1} 个节点失败:`, error);
      batchAddProgress.errors.push({
        index: i,
        message: '网络错误或服务异常'
      });
    }

    // 更新进度
    batchAddProgress.current = i + 1;
    console.log(`完成第 ${i + 1} 个创建请求，进度: ${batchAddProgress.current}/${batchAddProgress.total}`);

    // 强制UI更新
    await nextTick();

    // 更新进度类型
    if (batchAddProgress.errors.length > 0) {
      batchAddProgress.type = 'warning';
      batchAddProgress.progressStatus = 'danger';
    }

    // 添加延迟，让用户看到进度变化
    console.log(`等待延迟，当前新增进度: ${batchAddProgress.current}/${batchAddProgress.total}`);
    if (i < batchAddForm.value.count - 1) {
      await new Promise(resolve => setTimeout(resolve, 500)); // 500ms让用户能看到进度变化
    } else {
      // 最后一个请求完成后也等待一下
      await new Promise(resolve => setTimeout(resolve, 200));
    }
    console.log(`延迟结束，继续下一个创建请求`);

    // 在延迟前再次强制更新
    await nextTick();

  }

  // 设置最终进度
  batchAddProgress.current = batchAddForm.value.count;
  batchAddProgress.isProcessing = false;

  console.log('新增完成，等待3秒后显示结果...');

  // 等待3秒让用户看到进度条完成
  await new Promise(resolve => setTimeout(resolve, 3000));

  if (batchAddProgress.errors.length === 0) {
    batchAddProgress.type = 'success';
    batchAddProgress.progressStatus = 'success';
    Message.success(`成功创建 ${batchAddForm.value.count} 个节点`);
  } else {
    batchAddProgress.type = 'error';
    const successCount = batchAddProgress.success.length;
    Message.warning(`创建完成：成功 ${successCount} 个，失败 ${batchAddProgress.errors.length} 个`);
  }

  console.log('显示新增结果完成，等待2秒后可以关闭弹窗');

  // 再等待2秒让用户看到结果
  await new Promise(resolve => setTimeout(resolve, 2000));

  console.log('现在可以关闭新增弹窗了');

  // 刷新列表
  setTimeout(() => {
    getFunctionList();
  }, 1000);
};

// 检查是否有云账户
const checkCloudAccounts = async () => {
  try {
    const accounts = await getCloudAccountList();
    cloudAccountOptions.value = accounts;
    if (!accounts || accounts.length === 0) {
      Modal.warning({
        title: '提示',
        content: '当前系统中还没有配置云账户，请先配置云账户后再使用云函数功能。',
        okText: '去配置',
        onOk: () => {
          onCloudAccountManage();
        }
      });
    }
  } catch (error) {
    console.error('检查云账户失败:', error);
  }
};

onMounted(() => {
  getFunctionList();
  checkCloudAccounts();
});
</script>

