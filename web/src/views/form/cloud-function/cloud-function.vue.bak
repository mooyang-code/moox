const selectAll = (state: boolean) => {
  if (state) {
    // 只选择当前页的数据
    const currentPageNodeIds = functionList.value.map(el => el.node_id);
    // 合并当前选中的其他页数据和当前页数据
    const otherPagesSelected = selectedKeys.value.filter(key => !currentPageNodeIds.includes(key));
    selectedKeys.value = [...otherPagesSelected, ...currentPageNodeIds];
    console.log(`全选当前页: 当前页${currentPageNodeIds.length}个节点，其他页${otherPagesSelected.length}个节点，总计${selectedKeys.value.length}个节点`);
  } else {
    // 取消选择当前页的数据，但保留其他页的选择
    const currentPageNodeIds = functionList.value.map(el => el.node_id);
    selectedKeys.value = selectedKeys.value.filter(key => !currentPageNodeIds.includes(key));
    console.log(`取消选择当前页: 剩余${selectedKeys.value.length}个其他页节点`);
  }
};

