# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test


**/.claude/
bin/
log/
data/
# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work.sum

# env file
.env

server/.claude/

/var/
/bin/
/release/
/dist/
/coverage/
/modules/*/bin/
/modules/*/release/
/modules/*/.cache/
/modules/storage/.deps/
/modules/storage/data/
/scripts/node_exporter/build/
cover.out
cover.out.tmp

release/

*.log

**/trpc_go.yaml

# Editor/IDE
# .idea/
# .vscode/
