# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test


**/.claude/
.superpowers/

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work.sum

# env file
.env

server/.claude/

# Monorepo runtime/build artifacts. 真实运行数据应放到部署目录或 var，
# 仓库中只保留源码、配置模板、schema、文档和测试样例。
/bin/
/data/
/log/
/logs/
/var/
/release/
/dist/
/coverage/
/modules/*/bin/
/modules/*/data/
/modules/*/log/
/modules/*/logs/
/modules/*/var/
/modules/*/release/
/modules/*/dist/
/modules/*/coverage/
/modules/*/.cache/
/modules/*/scf-build/
/modules/storage/.deps/
/web-host/release/
/scripts/node_exporter/build/
cover.out
cover.out.tmp

*.log

**/trpc_go.yaml

# Editor/IDE
# .idea/
# .vscode/

# Local debug screenshots at repo root
/*.png

# Local web-host build artifact (use web-host/release or ./bin)
/web-host/web-host
/web-host/moox-web-host

# VitePress
node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/
